{
  "name": "BladeVault",
  "image": "mcr.microsoft.com/playwright:v1.61.1-noble",
  "workspaceFolder": "/workspaces/bladevault",
  "containerEnv": {
    "BLADEVAULT_DATA_DIR": "/workspaces/bladevault/data",
    "PLAYWRIGHT_BROWSERS_PATH": "/ms-playwright"
  },
  "mounts": [
    "source=bladevault-node-modules,target=/workspaces/bladevault/node_modules,type=volume"
  ],
  "postCreateCommand": "npm ci",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "BladeVault",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        }
      }
    }
  },
  "init": true
}
