<Container version="2">
  <Name>BladeVault</Name>
  <Repository>ghcr.io/dedkola/bladevault:latest</Repository>
  <Registry>https://ghcr.io/dedkola/bladevault</Registry>
  <Network>bridge</Network>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Icon>https://raw.githubusercontent.com/dedkola/bladevault/main/public/logo.png</Icon>
  <WebUI>http://[IP]:[PORT:3000]</WebUI>
  <Overview>BladeVault is a local-first knife collection manager. Organize and compare your collection, store images and a SQLite database in persistent appdata, and export knife records to PDF.</Overview>
  <Support>https://github.com/dedkola/bladevault/issues</Support>
  <Project>https://www.bladevault.pro</Project>
  <TemplateURL>https://raw.githubusercontent.com/dedkola/bladevault/main/templates/bladevault.xml</TemplateURL>
  <ReadMe>https://raw.githubusercontent.com/dedkola/bladevault/main/README.md</ReadMe>
  <Category>Tools:System</Category>
  <ExtraSearchTerms>knife collection inventory catalog manager local-first sqlite</ExtraSearchTerms>
  <Changes>Initial Unraid Community Apps release.</Changes>
  <Date>2026-07-15</Date>
  <License>MIT</License>
  <Screenshot>https://raw.githubusercontent.com/dedkola/bladevault/main/assets/screenshots/dashboard.png</Screenshot>
  <Screenshot>https://raw.githubusercontent.com/dedkola/bladevault/main/assets/screenshots/detail.png</Screenshot>
  <Screenshot>https://raw.githubusercontent.com/dedkola/bladevault/main/assets/screenshots/compare.png</Screenshot>
  <Screenshot>https://raw.githubusercontent.com/dedkola/bladevault/main/assets/screenshots/add.png</Screenshot>
  <Video>https://youtu.be/yurbpv0JY80</Video>
  <Config Name="WebUI" Target="3000" Default="5500" Mode="tcp" Description="HTTP port for the BladeVault web interface." Type="Port" Display="always" Required="true" Mask="false"/>
  <Config Name="Appdata" Target="/app/data" Default="/mnt/user/appdata/bladevault" Mode="rw" Description="Persistent SQLite database and downloaded knife images." Type="Path" Display="always" Required="true" Mask="false"/>
</Container>
